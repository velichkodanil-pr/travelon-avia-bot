# ============================================================================
# TravelON AVIA Message Bot — environment variables
# Copy to ".env" for local runs. On Railway set these as Variables.
# NEVER commit a real .env file (it is git-ignored).
# ============================================================================

# --- TravelON credentials (REQUIRED) ----------------------------------------
TRAVELON_EMAIL=your-login@example.com
TRAVELON_PASSWORD=your-password

# Base site URL and key pages (override only if the site moves).
TRAVELON_BASE_URL=https://travelon.to
TRAVELON_LOGIN_URL=https://travelon.to/admin/users/sign_in
TRAVELON_REQUESTS_URL=https://travelon.to/book/bundle/index

# --- Behaviour ---------------------------------------------------------------
# DRY_RUN=true -> finds matching requests, selects dept+subject, verifies the
# auto-filled text, and LOGS what it WOULD send. Sends nothing. Start here.
# Flip to false when the logs look right.
DRY_RUN=true
# Cron schedule (default: every 5 minutes). Uses CRON_TZ below.
CHECK_CRON=*/5 * * * *
# Run a single cycle then exit (testing). true/false.
RUN_ONCE=false
# Timezone for "today" and the cron schedule.
CRON_TZ=Europe/Kyiv
# Safety cap: never send more than this many messages in one cycle.
MAX_SENDS_PER_RUN=25
# How many list pages to page through per supplier when scanning.
AVIA_MAX_LIST_PAGES=5

# --- Matching: suppliers -----------------------------------------------------
# Matched to the "Постачальник" (filter[partner_id]) dropdown BY NAME at
# runtime — no partner IDs needed. Comma-separated, as shown in the dropdown.
AVIA_SUPPLIERS=DRCT,Tickets.ua,Fly One Avia,Skyup,JETIT,JETIT UAH
# Optional: pin exact partner IDs (same order as AVIA_SUPPLIERS) if name
# matching ever fails. Leave empty to match by name.
AVIA_SUPPLIER_IDS=

# --- Matching: statuses ------------------------------------------------------
# Status labels exactly as shown in the Status filter / row.
AVIA_STATUSES=In Work

# --- Matching: booking date --------------------------------------------------
# today          -> only requests whose booking (request) date is today
# today_or_later -> today and later
AVIA_BOOKING_DATE=today

# --- The message -------------------------------------------------------------
# Department option label in the chat composer.
AVIA_DEPARTMENT=Авіа
# Message-subject option label (backslashes are literal).
AVIA_SUBJECT=Бронювання на регулярному рейсі (ТІКЕТСИ\ДРСТ\СКАЙ АП)
# Loose regex to find the subject option if the exact label differs slightly.
AVIA_SUBJECT_RE=Бронювання\s+на\s+регулярному\s+рейс
# The bot verifies the AUTO-FILLED text contains this phrase before sending.
# It never overwrites the auto-filled text.
AVIA_EXPECTED_CONTAINS=заброньований на регулярн
# Recipient: everyone (default) or administrators.
AVIA_AUDIENCE=everyone

# --- Pegasus message (JETIT suppliers) --------------------------------------
# JETIT / JETIT UAH bookings get a SECOND message profile: same department
# (Авіа) but a different subject, and the bot replaces the single " _ "
# placeholder in the auto-filled text with the booking's "Transport Net"
# amount (Prices by modules), decimal-comma formatted (810.43 -> 810,43).
# Which suppliers use the Pegasus profile (comma-separated):
AVIA_PEGASUS_SUPPLIERS=JETIT,JETIT UAH
# Pegasus sends from a DIFFERENT department than regular avia ("Бронювання").
AVIA_PEGASUS_DEPARTMENT=Бронювання
# Pegasus subject option label.
AVIA_PEGASUS_SUBJECT=Бронювання авіаквитків Pegasus
# Loose regex to find the Pegasus subject option.
AVIA_PEGASUS_SUBJECT_RE=Бронювання\s+авіаквитків\s+Pegasus
# Phrase the Pegasus auto-fill must contain before sending.
AVIA_PEGASUS_EXPECTED_CONTAINS=заброньований на регулярн

# --- Browser -----------------------------------------------------------------
HEADLESS=true
SLOWMO_MS=0
NAV_TIMEOUT_MS=45000

# Persisted data (sent-IDs store + screenshots). On Railway attach a Volume and
# point this at its mount path to survive restarts (optional; the in-chat scan
# still prevents double-sends without it).
DATA_DIR=./data
SCREENSHOT_ON_ERROR=true

# --- Optional Telegram notifications -----------------------------------------
# If both are set, the bot posts a summary each cycle (great for dry-run).
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Google Sheets report (separate spreadsheet for AVIA) --------------------
# Tracks processed requests (one row per request, upsert by request №).
# OAuth user-token: acts as the Google account that OWNS the spreadsheet.
REPORT_ENABLED=false
# Spreadsheet ID from the URL: /spreadsheets/d/<THIS_ID>/edit
GOOGLE_SHEETS_SPREADSHEET_ID=
# Tab name (default "Avia").
GOOGLE_SHEETS_TAB=Avia
# OAuth client (Google Cloud Console) + refresh token with scope:
#   https://www.googleapis.com/auth/spreadsheets
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# --- Logging -----------------------------------------------------------------
# debug | info | warn | error
LOG_LEVEL=info
